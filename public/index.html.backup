<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agent Dashboard - OpenClaw</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Courier New', monospace;
            background: #1a1a2e;
            color: #e6e6e6;
            line-height: 1.6;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        header {
            text-align: center;
            margin-bottom: 30px;
            padding: 20px;
            background: #16213e;
            border-radius: 10px;
            border: 2px solid #0f3460;
        }
        
        h1 {
            color: #4cc9f0;
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(76, 201, 240, 0.5);
        }
        
        .subtitle {
            color: #a9a9a9;
            font-size: 1.2rem;
        }
        
        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .agent-card {
            background: #16213e;
            border-radius: 10px;
            padding: 20px;
            border: 2px solid #0f3460;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .agent-card:hover {
            transform: translateY(-5px);
            border-color: #4cc9f0;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }
        
        .agent-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .pixel-avatar {
            font-size: 3rem;
            margin-right: 15px;
            filter: drop-shadow(0 0 5px currentColor);
        }
        
        .agent-info h3 {
            color: #4cc9f0;
            font-size: 1.5rem;
            margin-bottom: 5px;
        }
        
        .agent-id {
            color: #a9a9a9;
            font-size: 0.9rem;
            font-family: monospace;
        }
        
        .status-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 8px;
        }
        
        .status-working { background: #4CAF50; box-shadow: 0 0 10px #4CAF50; }
        .status-idle { background: #FFC107; box-shadow: 0 0 10px #FFC107; }
        .status-error { background: #F44336; box-shadow: 0 0 10px #F44336; }
        .status-offline { background: #9E9E9E; }
        
        .status-text {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
            font-weight: bold;
        }
        
        .agent-details {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #0f3460;
        }
        
        .detail-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }
        
        .detail-label {
            color: #a9a9a9;
        }
        
        .detail-value {
            color: #e6e6e6;
            font-family: monospace;
        }
        
        .stats-bar {
            background: #0f3460;
            border-radius: 10px;
            padding: 20px;
            margin-top: 30px;
            margin-bottom: 40px; /* Добавляем отступ снизу */
            text-align: center;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }
        
        .stat-item {
            background: #16213e;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #0f3460;
        }
        
        .stat-value {
            font-size: 2rem;
            color: #4cc9f0;
            font-weight: bold;
        }
        
        .stat-label {
            color: #a9a9a9;
            font-size: 0.9rem;
            margin-top: 5px;
        }
        
        .last-update {
            text-align: center;
            color: #a9a9a9;
            font-size: 0.9rem;
            margin-top: 20px;
            padding: 10px;
            background: #16213e;
            border-radius: 5px;
            border: 1px solid #0f3460;
        }
        
        .connection-status {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 10px 15px;
            border-radius: 5px;
            font-size: 0.9rem;
            z-index: 1000;
        }
        
        .connected {
            background: rgba(76, 175, 80, 0.2);
            border: 1px solid #4CAF50;
            color: #4CAF50;
        }
        
        .disconnected {
            background: rgba(244, 67, 54, 0.2);
            border: 1px solid #F44336;
            color: #F44336;
        }
        
        @media (max-width: 768px) {
            .dashboard {
                grid-template-columns: 1fr;
            }
            
            h1 {
                font-size: 2rem;
            }
        }
        
        /* Стили для временной шкалы */
        .timeline-container {
            margin-top: 20px;
            padding: 20px;
            background: #16213e;
            border-radius: 10px;
            border: 2px solid #0f3460;
            display: none; /* Скрыто по умолчанию */
        }
        
        .timeline-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid #0f3460;
        }
        
        .timeline-title {
            color: #4cc9f0;
            font-size: 1.5rem;
        }
        
        .close-timeline {
            background: #f72585;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 5px;
            cursor: pointer;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        
        .close-timeline:hover {
            background: #b5179e;
            transform: scale(1.05);
        }
        
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 15px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #0f3460;
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 20px;
            padding: 15px;
            background: #1a1a2e;
            border-radius: 8px;
            border-left: 4px solid #4cc9f0;
        }
        
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -25px;
            top: 20px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #4cc9f0;
            box-shadow: 0 0 10px #4cc9f0;
        }
        
        .timeline-item.working { border-left-color: #4CAF50; }
        .timeline-item.working::before { background: #4CAF50; box-shadow: 0 0 10px #4CAF50; }
        
        .timeline-item.idle { border-left-color: #FFC107; }
        .timeline-item.idle::before { background: #FFC107; box-shadow: 0 0 10px #FFC107; }
        
        .timeline-item.error { border-left-color: #F44336; }
        .timeline-item.error::before { background: #F44336; box-shadow: 0 0 10px #F44336; }
        
        .timeline-time {
            color: #a9a9a9;
            font-size: 0.9rem;
            margin-bottom: 5px;
            font-family: monospace;
        }
        
        .timeline-status {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
            margin-right: 10px;
            text-transform: uppercase;
        }
        
        .timeline-status.working { background: rgba(76, 175, 80, 0.2); color: #4CAF50; }
        .timeline-status.idle { background: rgba(255, 193, 7, 0.2); color: #FFC107; }
        .timeline-status.error { background: rgba(244, 67, 54, 0.2); color: #F44336; }
        
        .timeline-task {
            color: #e6e6e6;
            margin-top: 8px;
            font-size: 1rem;
        }
        
        .timeline-duration {
            color: #a9a9a9;
            font-size: 0.8rem;
            margin-top: 5px;
            font-family: monospace;
        }
        
        .no-activity {
            text-align: center;
            padding: 30px;
            color: #a9a9a9;
            font-style: italic;
        }
        
        .view-activity-btn {
            background: rgba(76, 201, 240, 0.1);
            color: #4cc9f0;
            border: 1px solid #4cc9f0;
            padding: 6px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
            margin-top: 10px;
            transition: all 0.3s ease;
        }
        
        .view-activity-btn:hover {
            background: rgba(76, 201, 240, 0.3);
            transform: scale(1.05);
        }
        
        .loading-activity {
            text-align: center;
            padding: 20px;
            color: #a9a9a9;
        }
        
        /* Pixel art эффекты */
        .pixel-border {
            position: relative;
        }
        
        .pixel-border::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #4cc9f0, #f72585, #7209b7, #3a0ca3);
            border-radius: 12px;
            z-index: -1;
            animation: pixel-glow 2s ease-in-out infinite alternate;
        }
        
        @keyframes pixel-glow {
            0% { opacity: 0.5; }
            100% { opacity: 1; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header class="pixel-border">
            <h1>🕹️ AGENT DASHBOARD</h1>
            <p class="subtitle">Real-time monitoring of OpenClaw AI agents</p>
        </header>
        
        <div class="connection-status" id="connectionStatus">
            🔌 Connecting...
        </div>
        
        <div class="stats-bar">
            <h2>📊 SYSTEM STATS</h2>
            <div class="stats-grid" id="statsGrid">
                <!-- Stats will be populated by JavaScript -->
            </div>
        </div>
        
        <div class="dashboard" id="agentsGrid">
            <!-- Agent cards will be populated by JavaScript -->
            <div class="agent-card">
                <div class="agent-header">
                    <div class="pixel-avatar">🤖</div>
                    <div class="agent-info">
                        <h3>Loading agents...</h3>
                        <div class="agent-id">Waiting for connection</div>
                    </div>
                </div>
                <div class="status-text">
                    <span class="status-indicator status-idle"></span>
                    <span>CONNECTING TO SERVER</span>
                </div>
            </div>
        </div>
        
        <div class="last-update" id="lastUpdate">
            Last update: Never
        </div>
        
        <!-- Контейнер для временной шкалы активности -->
        <div class="timeline-container" id="timelineContainer">
            <div class="timeline-header">
                <h3 class="timeline-title" id="timelineTitle">История активности агента</h3>
                <button class="close-timeline" id="closeTimeline">✕ Закрыть</button>
            </div>
            <div class="timeline" id="timelineContent">
                <div class="loading-activity">Загрузка истории активности...</div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        // WebSocket connection
        const socket = io();
        const connectionStatus = document.getElementById('connectionStatus');
        const agentsGrid = document.getElementById('agentsGrid');
        const statsGrid = document.getElementById('statsGrid');
        const lastUpdate = document.getElementById('lastUpdate');
        
        // Connection status
        socket.on('connect', () => {
            console.log('Connected to server');
            connectionStatus.textContent = '✅ Connected';
            connectionStatus.className = 'connection-status connected';
        });
        
        socket.on('disconnect', () => {
            console.log('Disconnected from server');
            connectionStatus.textContent = '❌ Disconnected';
            connectionStatus.className = 'connection-status disconnected';
        });
        
        // Handle agents update
        socket.on('agents-update', (agents) => {
            console.log('Received agents update:', agents);
            updateDashboard(agents);
            updateLastUpdate();
        });
        
        // Initial load via REST API
        fetch('/api/agents')
            .then(response => response.json())
            .then(agents => {
                updateDashboard(agents);
                updateLastUpdate();
            })
            .catch(error => {
                console.error('Error fetching agents:', error);
            });
        
        function updateDashboard(agents) {
            // Update agents grid
            if (agents.length === 0) {
                agentsGrid.innerHTML = `
                    <div class="agent-card pixel-border">
                        <div class="agent-header">
                            <div class="pixel-avatar">👻</div>
                            <div class="agent-info">
                                <h3>Агентов нет</h3>
                                <div class="agent-id">Создайте первого агента!</div>
                            </div>
                        </div>
                        <div class="status-text">
                            <span class="status-indicator status-offline"></span>
                            <span>ОЖИДАНИЕ АГЕНТОВ</span>
                        </div>
                        <div class="agent-details">
                            <div class="detail-item">
                                <span class="detail-label">Статус:</span>
                                <span class="detail-value">Дашборд готов</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Инструкция:</span>
                                <span class="detail-value">Создайте агентов через OpenClaw</span>
                            </div>
                        </div>
                    </div>
                `;
                
                // Update stats for empty state
                statsGrid.innerHTML = `
                    <div class="stat-item">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Всего агентов</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Работающих</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Бездействующих</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Ошибок</div>
                    </div>
                `;
                return;
            }
            
            agentsGrid.innerHTML = agents.map(agent => `
                <div class="agent-card">
                    <div class="agent-header">
                        <div class="pixel-avatar">${agent.emoji || agent.sprite || '🤖'}</div>
                        <div class="agent-info">
                            <h3>${agent.name}</h3>
                            <div class="agent-id">ID: ${agent.id}</div>
                        </div>
                    </div>
                    <div class="status-text">
                        <span class="status-indicator status-${agent.status}"></span>
                        <span>${agent.status.toUpperCase()}</span>
                    </div>
                    <div class="agent-details">
                        <div class="detail-item">
                            <span class="detail-label">Рабочая область:</span>
                            <span class="detail-value">${agent.workspace}</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Последняя активность:</span>
                            <span class="detail-value">${new Date(agent.lastSeen).toLocaleTimeString()}</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Описание:</span>
                            <span class="detail-value">${agent.description || 'AI-агент'}</span>
                        </div>
                        <button class="view-activity-btn" onclick="viewAgentActivity('${agent.id}', '${agent.name}')">📊 Показать историю активности</button>
                    </div>
                </div>
            `).join('');
            
            // Update stats
            const workingCount = agents.filter(a => a.status === 'working').length;
            const idleCount = agents.filter(a => a.status === 'idle').length;
            const errorCount = agents.filter(a => a.status === 'error').length;
            
            statsGrid.innerHTML = `
                <div class="stat-item">
                    <div class="stat-value">${agents.length}</div>
                    <div class="stat-label">Total Agents</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">${workingCount}</div>
                    <div class="stat-label">Working</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">${idleCount}</div>
                    <div class="stat-label">Idle</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">${errorCount}</div>
                    <div class="stat-label">Errors</div>
                </div>
            `;
        }
        
        function updateLastUpdate() {
            const now = new Date();
            lastUpdate.textContent = `Last update: ${now.toLocaleTimeString()}`;
        }
        
        // Auto-refresh every 30 seconds as backup
        setInterval(() => {
            fetch('/api/agents')
                .then(response => response.json())
                .then(agents => {
                    updateDashboard(agents);
                    updateLastUpdate();
                });
        }, 30000);
        
        // Функции для работы с временной шкалой активности
        function viewAgentActivity(agentId, agentName) {
            // Показываем контейнер
            const container = document.getElementById('timelineContainer');
            const title = document.getElementById('timelineTitle');
            const content = document.getElementById('timelineContent');
            
            title.textContent = `История активности: ${agentName}`;
            content.innerHTML = '<div class="loading-activity">Загрузка истории активности...</div>';
            container.style.display = 'block';
            
            // Прокручиваем к временной шкале
            container.scrollIntoView({ behavior: 'smooth' });
            
            // Загружаем историю активности
            fetch(`/api/agents/${agentId}/activity?limit=15`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.activity.length > 0) {
                        renderTimeline(data.activity);
                    } else {
                        content.innerHTML = '<div class="no-activity">Нет данных об активности</div>';
                    }
                })
                .catch(error => {
                    console.error('Error loading activity:', error);
                    content.innerHTML = '<div class="no-activity">Ошибка загрузки истории активности</div>';
                });
        }
        
        function renderTimeline(activities) {
            const content = document.getElementById('timelineContent');
            
            // Сортируем по времени (новые сверху)
            activities.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            
            if (activities.length === 0) {
                content.innerHTML = '<div class="no-activity">Нет данных об активности</div>';
                return;
            }
            
            const timelineHTML = activities.map(activity => {
                const time = new Date(activity.timestamp);
                const duration = activity.duration ? formatDuration(activity.duration) : 'В процессе';
                
                return `
                    <div class="timeline-item ${activity.status}">
                        <div class="timeline-time">${time.toLocaleString()}</div>
                        <span class="timeline-status ${activity.status}">${activity.status.toUpperCase()}</span>
                        <div class="timeline-task">${activity.task}</div>
                        <div class="timeline-duration">⏱️ Длительность: ${duration}</div>
                    </div>
                `;
            }).join('');
            
            content.innerHTML = timelineHTML;
        }
        
        function formatDuration(ms) {
            if (ms < 1000) return `${ms}мс`;
            
            const seconds = Math.floor(ms / 1000);
            if (seconds < 60) return `${seconds}сек`;
            
            const minutes = Math.floor(seconds / 60);
            if (minutes < 60) return `${minutes}мин`;
            
            const hours = Math.floor(minutes / 60);
            const remainingMinutes = minutes % 60;
            return `${hours}ч ${remainingMinutes}мин`;
        }
        
        // Закрытие временной шкалы
        document.getElementById('closeTimeline').addEventListener('click', () => {
            document.getElementById('timelineContainer').style.display = 'none';
        });
        
        // WebSocket обработчик для обновления истории активности
        socket.on('agent-activity', (data) => {
            // Если открыта временная шкала для этого агента, обновляем
            const container = document.getElementById('timelineContainer');
            if (container.style.display === 'block') {
                const title = document.getElementById('timelineTitle').textContent;
                if (title.includes(data.agentId)) {
                    renderTimeline(data.activity);
                }
            }
        });
        
        // Запрос истории активности через WebSocket
        function requestAgentActivity(agentId) {
            socket.emit('get-agent-activity', agentId);
        }
    </script>
</body>
</html>